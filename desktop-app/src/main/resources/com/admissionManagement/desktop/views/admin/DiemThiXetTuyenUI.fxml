<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.admissionManagement.desktop.controllers.admin.DiemThiXetTuyenController"
      styleClass="screen-root" spacing="12">

    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <!-- Stat cards -->
    <HBox spacing="12">
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card" spacing="4">
            <Label text="Điểm TB THPT" styleClass="stat-label"/>
            <Label fx:id="lblTbThpt" text="--" styleClass="stat-value"/>
            <Label text="toàn bộ thí sinh" styleClass="stat-sub"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card" spacing="4">
            <Label text="Điểm TB VSAT" styleClass="stat-label"/>
            <Label fx:id="lblTbVsat" text="--" styleClass="stat-value"/>
            <Label text="thang điểm 1000" styleClass="stat-sub"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card" spacing="4">
            <Label text="Điểm TB ĐGNL" styleClass="stat-label"/>
            <Label fx:id="lblTbDgnl" text="--" styleClass="stat-value"/>
            <Label text="thang điểm 1200" styleClass="stat-sub"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card" spacing="4">
            <Label text="Đã nhập điểm" styleClass="stat-label"/>
            <Label fx:id="lblDaNhap" text="--" styleClass="stat-value"/>
            <Label fx:id="lblDaNhapSub" text="/ 0 thí sinh" styleClass="stat-sub"/>
        </VBox>
    </HBox>

    <!-- Chart -->
    <VBox styleClass="inline-form-card" spacing="6">
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="Phân bố điểm trung bình theo môn" styleClass="inline-form-title"/>
            <ComboBox fx:id="cbLoaiDiem" prefWidth="130" onAction="#onChartFilter"/>
        </HBox>
        <BarChart fx:id="barChart" prefHeight="180" legendVisible="false"
                  animated="false" styleClass="chart-main">
            <xAxis><CategoryAxis label=""/></xAxis>
            <yAxis><NumberAxis label="Điểm TB"/></yAxis>
        </BarChart>
    </VBox>

    <!-- Toolbar -->
    <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
        <Button text="+ Thêm"       styleClass="btn-primary"  onAction="#onAdd"/>
        <Button text="✎ Sửa"        styleClass="btn-warning"  onAction="#onEdit"/>
        <Button text="✕ Xóa"        styleClass="btn-danger"   onAction="#onDeleteSelected"/>
        <Button text="⬆ Import CSV" styleClass="btn-primary"  onAction="#onImport"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="tfSearch"
                   promptText="Tìm theo CCCD, số báo danh..."
                   styleClass="search-box" prefWidth="240"/>
        <ComboBox fx:id="cbLoaiDiemFilter"
                  promptText="Tất cả loại điểm"
                  styleClass="combo-box-filter" prefWidth="150"
                  onAction="#onFilter"/>
    </HBox>


    <!-- Table -->
    <VBox VBox.vgrow="ALWAYS" styleClass="table-card">
        <TableView fx:id="tblDiem" VBox.vgrow="ALWAYS" styleClass="main-table"
                   style="-fx-pref-width: 9999;">
            <columns>
                <!-- Thông tin chung -->
                <TableColumn fx:id="colCccd"      text="CCCD"        prefWidth="150" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colSbd"        text="Số báo danh" prefWidth="120" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colPhuongThuc" text="Phương thức" prefWidth="110" style="-fx-alignment:CENTER;"/>

                <!-- Điểm THPT -->
                <TableColumn text="Điểm THPT">
                    <columns>
                        <TableColumn fx:id="colToan"  text="Toán"            prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colVan"   text="Văn"             prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colLy"    text="Vật lý"          prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colHoa"   text="Hóa học"         prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colSinh"  text="Sinh học"        prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colSu"    text="Lịch sử"         prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colDia"   text="Địa lý"          prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colTin"   text="Tin học"         prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colKtpl"  text="KTPL"            prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colN1Thi" text="Ngoại ngữ (thi)" prefWidth="120" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colN1Cc"  text="Ngoại ngữ (CC)"  prefWidth="120" style="-fx-alignment:CENTER;"/>
                    </columns>
                </TableColumn>

                <!-- Điểm VSAT -->
                <TableColumn text="Điểm VSAT">
                    <columns>
                        <TableColumn fx:id="colToanVsat" text="Toán"      prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colVanVsat"  text="Văn"       prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colLyVsat"   text="Vật lý"    prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colHoaVsat"  text="Hóa học"   prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colSinhVsat" text="Sinh học"  prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colSuVsat"   text="Lịch sử"   prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colDiaVsat"  text="Địa lý"    prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colN1Vsat"   text="Ngoại ngữ" prefWidth="100" style="-fx-alignment:CENTER;"/>
                    </columns>
                </TableColumn>

                <!-- ĐGNL & Năng khiếu -->
                <TableColumn text="ĐGNL / Năng khiếu">
                    <columns>
                        <TableColumn fx:id="colNl1"  text="ĐGNL" prefWidth="90" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colCncn" text="CNCN" prefWidth="80" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colCnnn" text="CNNN" prefWidth="80" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colNk1"  text="NK1"  prefWidth="70" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colNk2"  text="NK2"  prefWidth="70" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colNk3"  text="NK3"  prefWidth="70" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colNk4"  text="NK4"  prefWidth="70" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colNk5"  text="NK5"  prefWidth="70" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colNk6"  text="NK6"  prefWidth="70" style="-fx-alignment:CENTER;"/>
                    </columns>
                </TableColumn>


            </columns>
            <placeholder>
                <Label text="Không có dữ liệu" styleClass="table-placeholder"/>
            </placeholder>
        </TableView>
        <HBox styleClass="pagination-bar" alignment="CENTER_RIGHT" spacing="8">
            <Label fx:id="lblCount" text="0 bản ghi" styleClass="record-count"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Pagination fx:id="pagination" pageCount="1" maxPageIndicatorCount="7"
                        styleClass="table-pagination"/>
        </HBox>
    </VBox>
</VBox>