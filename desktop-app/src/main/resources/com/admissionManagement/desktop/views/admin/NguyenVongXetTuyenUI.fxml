<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.admissionManagement.desktop.controllers.admin.NguyenVongXetTuyenController"
      styleClass="screen-root" spacing="12">

    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="tfSearch" promptText="Tìm theo CCCD thí sinh..."
                   styleClass="search-box" prefWidth="260"/>
        <Button text="+ Thêm mới" styleClass="btn-primary" onAction="#onAdd"/>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="table-card">
        <TableView fx:id="tblNguyenVong" VBox.vgrow="ALWAYS" styleClass="main-table">
            <columns>
                <TableColumn fx:id="colId"          text="ID"              prefWidth="60"  style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colCccd"         text="CCCD"            prefWidth="140" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colMaNganh"      text="Mã ngành"        prefWidth="100" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colThuTu"        text="Thứ tự NV"       prefWidth="90"  style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colPhuongThuc"   text="Phương thức"     prefWidth="110" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colToHop"        text="Tổ hợp"          prefWidth="90"  style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colDiemTHXT"     text="Điểm THXT"       prefWidth="100" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colDiemUTQD"     text="Điểm UTQD"       prefWidth="100" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colDiemCong"     text="Điểm cộng"       prefWidth="100" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colDiemXT"       text="Điểm xét tuyển"  prefWidth="120" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colKetQua"       text="Kết quả"         prefWidth="110" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colNvKeys"       text="NV Keys"         prefWidth="150" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colAction"       text="Thao tác"        prefWidth="120" style="-fx-alignment:CENTER;"/>
            </columns>
            <placeholder>
                <Label text="Không có dữ liệu" styleClass="table-placeholder"/>
            </placeholder>
        </TableView>
        <HBox styleClass="pagination-bar" alignment="CENTER_RIGHT">
            <Label fx:id="lblCount" text="0 bản ghi" styleClass="record-count"/>
        </HBox>
    </VBox>
</VBox>