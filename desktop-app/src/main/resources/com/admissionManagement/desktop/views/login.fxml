<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<?import java.net.URL?>
<VBox alignment="CENTER" spacing="15.0" styleClass="login-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.admissionManagement.desktop.controllers.LoginController">
    <stylesheets>
        <URL value="@../styles/global.css" />
        <URL value="@../styles/login.css" />
    </stylesheets>
    <children>
        <Label styleClass="title-label" text="HỆ THỐNG TUYỂN SINH" />
        <Label styleClass="subtitle-label" text="Đăng nhập Quản trị viên" />

        <VBox maxWidth="300.0" spacing="8.0">
            <children>
                <Label text="Tên đăng nhập / CCCD:" />
                <TextField fx:id="txtUsername" promptText="Nhập tài khoản..." styleClass="input-field" />

                <Label text="Mật khẩu:" />
                <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu..." styleClass="input-field" />
            </children>
        </VBox>

        <Label fx:id="lblError" styleClass="error-label" text="Sai tài khoản hoặc mật khẩu!" visible="false" />

        <Button fx:id="btnLogin" mnemonicParsing="false" onAction="#handleLogin" prefWidth="300.0" styleClass="btn-primary" text="Đăng Nhập" />
    </children>

    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>
</VBox>