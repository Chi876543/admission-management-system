<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.admissionManagement.desktop.controllers.admin.ThiSinhController"
      styleClass="screen-root" spacing="12">

    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
        <Button text="+ Thêm mới"   styleClass="btn-success"  onAction="#onAdd"/>
        <Button text="⬆ Import CSV" styleClass="btn-primary"  onAction="#onImport"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="tfSearch" promptText="Tìm theo CCCD, họ tên..."
                   styleClass="search-box" prefWidth="260" onKeyReleased="#onSearch"/>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="table-card">
        <TableView fx:id="tblThiSinh" VBox.vgrow="ALWAYS" styleClass="main-table">
            <columns>
                <TableColumn fx:id="colId"       text="ID"          prefWidth="60"  style="-fx-alignment:CENTER;"/>

                <TableColumn fx:id="colSbd"      text="SBD"         prefWidth="100"/>
                <TableColumn fx:id="colCccd"     text="CCCD"        prefWidth="120"/>
                <TableColumn fx:id="colHo"       text="Họ và đệm"   prefWidth="140"/>
                <TableColumn fx:id="colTen"      text="Tên"/>
                <TableColumn fx:id="colNgaySinh" text="Ngày sinh"   prefWidth="90"  style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colGioiTinh" text="Giới tính"   prefWidth="70"  style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colSdt"      text="Điện thoại"  prefWidth="100"/>
                <TableColumn fx:id="colEmail"    text="Email"       prefWidth="160"/>
                <TableColumn fx:id="colNoiSinh"  text="Nơi sinh"    prefWidth="100"/>
                <TableColumn fx:id="colDoiTuong" text="Đối tượng" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colKhuVuc"   text="Khu vực"     prefWidth="70"  style="-fx-alignment:CENTER;"/>

                <TableColumn fx:id="colAction"   text="Thao tác"    prefWidth="110" style="-fx-alignment:CENTER;"/>
            </columns>
            <placeholder><Label text="Không có dữ liệu" styleClass="table-placeholder"/></placeholder>
        </TableView>
        <HBox styleClass="pagination-bar" alignment="CENTER_RIGHT" spacing="8">
            <Label fx:id="lblCount" text="0 thí sinh" styleClass="record-count"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Pagination fx:id="pagination" pageCount="1" maxPageIndicatorCount="7"
                        styleClass="table-pagination"/>
        </HBox>
    </VBox>
</VBox>