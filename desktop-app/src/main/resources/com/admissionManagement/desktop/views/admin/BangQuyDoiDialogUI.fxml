<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.admissionManagement.desktop.controllers.admin.BangQuyDoiDialogController"
      styleClass="screen-root"
      spacing="12"
      prefWidth="480">

    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <Label fx:id="lblDialogTitle"
           text="Thêm luật quy đổi mới"
           styleClass="inline-form-title"/>

    <VBox styleClass="inline-form-card"
          spacing="10">

        <HBox spacing="12">

            <VBox HBox.hgrow="ALWAYS"
                  spacing="4">

                <Label text="Phương thức *"/>

                <ComboBox fx:id="cbPhuongThuc"
                          promptText="Chọn phương thức"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS"
                  spacing="4">

                <Label text="Tổ hợp"/>

                <ComboBox fx:id="cbToHop"
                          promptText="Chọn tổ hợp"/>
            </VBox>

        </HBox>

        <HBox spacing="12">

            <VBox HBox.hgrow="ALWAYS"
                  spacing="4">

                <Label text="Môn"/>

                <ComboBox fx:id="cbMon"
                          promptText="Chọn môn"/>
            </VBox>

        </HBox>

        <HBox spacing="12">

            <VBox HBox.hgrow="ALWAYS"
                  spacing="4">

                <Label text="Điểm A"/>

                <TextField fx:id="tfDiemA"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS"
                  spacing="4">

                <Label text="Điểm B"/>

                <TextField fx:id="tfDiemB"/>
            </VBox>

        </HBox>

        <HBox spacing="12">

            <VBox HBox.hgrow="ALWAYS"
                  spacing="4">

                <Label text="Điểm C"/>

                <TextField fx:id="tfDiemC"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS"
                  spacing="4">

                <Label text="Điểm D"/>

                <TextField fx:id="tfDiemD"/>
            </VBox>

        </HBox>

        <Label fx:id="lblError"
               styleClass="error-label"/>

        <HBox spacing="8">

            <Button text="Lưu"
                    styleClass="btn-primary"
                    onAction="#onDialogSave"/>

            <Button text="Hủy"
                    styleClass="btn-default"
                    onAction="#onDialogCancel"/>

        </HBox>

    </VBox>

</VBox>