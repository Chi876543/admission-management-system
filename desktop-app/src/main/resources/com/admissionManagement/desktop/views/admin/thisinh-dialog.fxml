<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.admissionManagement.desktop.controllers.admin.ThiSinhController"
      styleClass="dialog-root" spacing="12" prefWidth="460">

    <padding><Insets top="20" right="24" bottom="8" left="24"/></padding>

    <Label fx:id="lblDialogTitle" text="Thêm thí sinh" styleClass="dialog-title"/>

    <HBox spacing="12">
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <Label text="CCCD *" styleClass="field-label"/>
            <TextField fx:id="tfCccd" promptText="12 chữ số" styleClass="field-input"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <Label text="Ngày sinh *" styleClass="field-label"/>
            <DatePicker fx:id="dpNgaySinh" styleClass="field-input" maxWidth="Infinity"/>
        </VBox>
    </HBox>

    <VBox spacing="4">
        <Label text="Họ và tên *" styleClass="field-label"/>
        <TextField fx:id="tfHoTen" promptText="Nhập họ tên đầy đủ" styleClass="field-input"/>
    </VBox>

    <HBox spacing="12">
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <Label text="Giới tính" styleClass="field-label"/>
            <ComboBox fx:id="cbGioiTinh" maxWidth="Infinity" styleClass="field-input"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <Label text="Điện thoại" styleClass="field-label"/>
            <TextField fx:id="tfSdt" promptText="0xxxxxxxxx" styleClass="field-input"/>
        </VBox>
    </HBox>

    <VBox spacing="4">
        <Label text="Email" styleClass="field-label"/>
        <TextField fx:id="tfEmail" promptText="example@gmail.com" styleClass="field-input"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Địa chỉ" styleClass="field-label"/>
        <TextArea fx:id="tadiaChi" promptText="Địa chỉ thường trú..." styleClass="field-input"
                  prefRowCount="2" wrapText="true"/>
    </VBox>

    <Label fx:id="lblError" text="" styleClass="error-label" wrapText="true"/>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <padding><Insets top="4" bottom="8"/></padding>
        <Button text="Hủy" styleClass="btn-default" onAction="#onDialogCancel"/>
        <Button text="Lưu" styleClass="btn-primary" onAction="#onDialogSave" defaultButton="true"/>
    </HBox>
</VBox>
