<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.admissionManagement.desktop.controllers.admin.DiemCongXetTuyenController"
      styleClass="screen-root"
      spacing="12">

    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <HBox styleClass="toolbar"
          spacing="8"
          alignment="CENTER_LEFT">

        <Button text="+ Thêm mới"
                styleClass="btn-primary"
                onAction="#onAdd"/>

        <Button fx:id="btnEdit"
                text="✏ Sửa"
                styleClass="btn-warning"
                onAction="#onEdit"/>

        <Button fx:id="btnDelete"
                text="🗑 Xóa"
                styleClass="btn-danger"
                onAction="#onDelete"/>

        <Button text="⬆ Import UTXT"
                styleClass="btn-primary"
                onAction="#onImportUtxt"/>

        <Button text="⬆ Import CC"
                styleClass="btn-primary"
                onAction="#onImportCc"/>

        <Button text="+ Thêm CC"
                styleClass="btn-primary"
                onAction="#onAddCc"/>

        <Button text="✏ Sửa CC"
                styleClass="btn-warning"
                onAction="#onEditCc"/>

        <Region HBox.hgrow="ALWAYS"/>

        <TextField fx:id="tfSearch"
                   promptText="Tìm CCCD, môn, phương thức..."
                   styleClass="search-box"
                   prefWidth="300"/>
    </HBox>

    <VBox VBox.vgrow="ALWAYS"
          styleClass="table-card">

        <TableView fx:id="tblDiemCong"
                   VBox.vgrow="ALWAYS"
                   styleClass="main-table">

            <columns>

                <TableColumn fx:id="colId"
                             text="ID"
                             prefWidth="60"
                             style="-fx-alignment:CENTER;"/>

                <TableColumn fx:id="colCccd"
                             text="CCCD"
                             prefWidth="150"
                             style="-fx-alignment:CENTER;"/>

                <TableColumn fx:id="colMon"
                             text="Môn"
                             prefWidth="120"
                             style="-fx-alignment:CENTER;"/>

                <TableColumn fx:id="colPhuongThuc"
                             text="Phương thức"
                             prefWidth="120"
                             style="-fx-alignment:CENTER;"/>

                <TableColumn fx:id="colDiemUtxtToHop"
                             text="UTXT tổ hợp"
                             prefWidth="120"
                             style="-fx-alignment:CENTER;"/>

                <TableColumn fx:id="colDiemUtxtKhongToHop"
                             text="UTXT không TH"
                             prefWidth="140"
                             style="-fx-alignment:CENTER;"/>

                <TableColumn fx:id="colDiemCc"
                             text="Điểm CC"
                             prefWidth="100"
                             style="-fx-alignment:CENTER;"/>

                <TableColumn fx:id="colTongThxt"
                             text="Tổng THXT"
                             prefWidth="120"
                             style="-fx-alignment:CENTER;"/>

                <TableColumn fx:id="colTongKhongThxt"
                             text="Tổng không THXT"
                             prefWidth="150"
                             style="-fx-alignment:CENTER;"/>

                <TableColumn fx:id="colGhiChu"
                             text="Ghi chú"
                             prefWidth="220"/>
            </columns>

            <placeholder>
                <Label text="Không có dữ liệu"
                       styleClass="table-placeholder"/>
            </placeholder>

        </TableView>

        <HBox styleClass="pagination-bar"
              alignment="CENTER_RIGHT"
              spacing="12">

            <Label fx:id="lblCount"
                   text="0 bản ghi"
                   styleClass="record-count"/>

            <Pagination fx:id="pagination"
                        maxPageIndicatorCount="5"/>
        </HBox>

    </VBox>

</VBox>