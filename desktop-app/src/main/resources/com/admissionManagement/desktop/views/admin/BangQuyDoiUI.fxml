<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.admissionManagement.desktop.controllers.admin.BangQuyDoiController"
      styleClass="screen-root"
      spacing="12">

    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <HBox styleClass="toolbar"
          spacing="8"
          alignment="CENTER_LEFT">

        <Button text="+ Thêm mới"
                styleClass="btn-primary"
                onAction="#onAdd"/>

        <Button text="✎ Sửa"
                styleClass="btn-warning"
                onAction="#onEdit"/>

        <Button text="✕ Xóa"
                styleClass="btn-danger"
                onAction="#onDeleteSelected"/>

        <Button text="⬆ Import CSV"
                styleClass="btn-default"
                onAction="#onImport"/>

        <Region HBox.hgrow="ALWAYS"/>

        <TextField fx:id="tfSearch"
                   promptText="Tìm kiếm..."
                   styleClass="search-box"
                   prefWidth="260"/>

    </HBox>

    <VBox VBox.vgrow="ALWAYS"
          styleClass="table-card">

        <TableView fx:id="tblBangQuyDoi"
                   VBox.vgrow="ALWAYS"
                   styleClass="main-table">

            <columns>

                <TableColumn fx:id="colId"
                             text="ID"
                             prefWidth="60"/>

                <TableColumn fx:id="colPhuongThuc"
                             text="Phương thức"
                             prefWidth="140"/>

                <TableColumn fx:id="colToHop"
                             text="Tổ hợp"
                             prefWidth="100"/>

                <TableColumn fx:id="colMon"
                             text="Môn"
                             prefWidth="120"/>

                <TableColumn fx:id="colDiemA"
                             text="Điểm A"
                             prefWidth="100"/>

                <TableColumn fx:id="colDiemB"
                             text="Điểm B"
                             prefWidth="100"/>

                <TableColumn fx:id="colDiemC"
                             text="Điểm C"
                             prefWidth="100"/>

                <TableColumn fx:id="colDiemD"
                             text="Điểm D"
                             prefWidth="100"/>

            </columns>

        </TableView>

        <HBox styleClass="pagination-bar"
              alignment="CENTER_RIGHT">

            <Label fx:id="lblCount"
                   text="0 bản ghi"
                   styleClass="record-count"/>

        </HBox>

    </VBox>

</VBox>