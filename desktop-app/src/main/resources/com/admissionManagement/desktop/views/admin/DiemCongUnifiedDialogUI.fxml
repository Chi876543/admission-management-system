<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.admissionManagement.desktop.controllers.admin.DiemCongUnifiedDialogController"
      styleClass="screen-root"
      spacing="12"
      prefWidth="560">

    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <Label fx:id="lblDialogTitle"
           text="Thêm điểm cộng"
           styleClass="inline-form-title"/>

    <TabPane fx:id="tabPane" styleClass="tab-pane">

        <!-- ── Tab UTXT ──────────────────────────────────────── -->
        <Tab text="Ưu tiên xét tuyển (UTXT)" closable="false">
            <VBox spacing="12" styleClass="inline-form-card">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

                <HBox spacing="12">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="CCCD *" styleClass="field-label"/>
                        <TextField fx:id="tfCccdUtxt" promptText="Nhập CCCD" styleClass="field-input"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Phương thức *" styleClass="field-label"/>
                        <ComboBox fx:id="cbPhuongThucUtxt" maxWidth="Infinity" styleClass="field-input"/>
                    </VBox>
                </HBox>

                <HBox spacing="12">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Môn *" styleClass="field-label"/>
                        <ComboBox fx:id="cbMonUtxt" maxWidth="Infinity" styleClass="field-input"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Loại giải *" styleClass="field-label"/>
                        <ComboBox fx:id="cbLoaiGiai" maxWidth="Infinity" styleClass="field-input"/>
                    </VBox>
                </HBox>

                <HBox spacing="12">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Cấp *" styleClass="field-label"/>
                        <ComboBox fx:id="cbCap" maxWidth="Infinity" styleClass="field-input"/>
                    </VBox>
                </HBox>

                <VBox spacing="4">
                    <Label text="Ghi chú (tự động từ combobox)" styleClass="field-label"/>
                    <TextField fx:id="tfGhiChuUtxt" promptText="Tự điền theo giải và cấp" styleClass="field-input"/>
                </VBox>
            </VBox>
        </Tab>

        <!-- ── Tab CC ─────────────────────────────────────────── -->
        <Tab text="Chứng chỉ tiếng Anh (CC)" closable="false">
            <VBox spacing="12" styleClass="inline-form-card">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

                <HBox spacing="12">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="CCCD *" styleClass="field-label"/>
                        <TextField fx:id="tfCccdCc" promptText="Nhập CCCD" styleClass="field-input"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Phương thức *" styleClass="field-label"/>
                        <ComboBox fx:id="cbPhuongThucCc" maxWidth="Infinity" styleClass="field-input"/>
                    </VBox>
                </HBox>

                <VBox spacing="4">
                    <Label text="Mức điểm chứng chỉ *" styleClass="field-label"/>
                    <ComboBox fx:id="cbMucDiem" maxWidth="Infinity" promptText="Chọn mức điểm" styleClass="field-input"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Ghi chú chứng chỉ" styleClass="field-label"/>
                    <TextField fx:id="tfGhiChuCc" promptText="VD: IELTS 6.5" styleClass="field-input"/>
                </VBox>

                <Label fx:id="lblPreviewCc" text="" style="-fx-text-fill:#2563eb; -fx-font-size:13px;"/>
            </VBox>
        </Tab>

    </TabPane>

    <!-- Error + Buttons -->
    <Label fx:id="lblError" text="" styleClass="error-label"/>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Lưu"  styleClass="btn-primary" onAction="#onDialogSave"/>
        <Button text="Hủy"  styleClass="btn-default"  onAction="#onDialogCancel"/>
    </HBox>

</VBox>
