<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.admissionManagement.desktop.controllers.admin.NguyenVongXetTuyenDialogController"
      styleClass="screen-root"
      spacing="12"
      prefWidth="420">

    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <Label fx:id="lblDialogTitle"
           text="Thêm nguyện vọng mới"
           styleClass="inline-form-title"/>

    <VBox styleClass="inline-form-card"
          spacing="10">

        <VBox spacing="4">

            <Label text="CCCD *"
                   styleClass="field-label"/>

            <TextField fx:id="tfCccd"
                       promptText="VD: 012345678901"
                       styleClass="field-input"/>
        </VBox>

        <VBox spacing="4">

            <Label text="Ngành *"
                   styleClass="field-label"/>

            <ComboBox fx:id="cbMaNganh"
                      promptText="Chọn ngành"
                      maxWidth="Infinity"/>
        </VBox>

        <VBox spacing="4">

            <Label text="Thứ tự nguyện vọng *"
                   styleClass="field-label"/>

            <TextField fx:id="tfThuTu"
                       promptText="VD: 1"
                       styleClass="field-input"/>
        </VBox>

        <Label fx:id="lblError"
               text=""
               styleClass="error-label"/>

        <HBox spacing="8">

            <Button text="Lưu"
                    styleClass="btn-primary"
                    onAction="#onDialogSave"/>

            <Button text="Hủy"
                    styleClass="btn-default"
                    onAction="#onDialogCancel"/>
        </HBox>

    </VBox>
</VBox>